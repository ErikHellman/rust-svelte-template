# Copy to .env and fill in. The `just dev` target reads .env automatically.

# ---- Required ------------------------------------------------------------

# Path is relative to the backend/ directory when running `just dev-backend`.
DATABASE_URL=sqlite://../data/app.db?mode=rwc

# Where the API binds.
BIND_ADDR=0.0.0.0:3000

# The public URL the SPA uses to reach the API. In dev this is the Vite host
# (which proxies /api to the backend). In prod, the same origin that serves
# the SPA. Used to build OAuth redirect URIs.
PUBLIC_BASE_URL=http://localhost:5173

# Cookie signing secret (HMAC). Generate with: openssl rand -hex 32
COOKIE_SECRET=replace-me-with-a-real-secret-of-at-least-32-bytes

# Run `just gen-jwt-keys` to generate a fresh RSA keypair and print the env
# lines to paste here. Both vars use literal \n escapes for multi-line PEMs.
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# ---- Optional ------------------------------------------------------------

JWT_ISSUER=full-stack-template
ACCESS_TOKEN_TTL_SECS=900
REFRESH_TOKEN_TTL_SECS=2592000

# ---- OAuth providers (only fill in the ones you use) ---------------------
# Redirect URIs to configure with each provider:
#   http://localhost:5173/api/auth/<provider>/callback   (dev)
#   https://yourapp.com/api/auth/<provider>/callback     (prod)

# Google: https://console.cloud.google.com → APIs & Services → Credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Microsoft: https://entra.microsoft.com → App registrations
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT=common

# Apple: https://developer.apple.com → Identifiers → Services IDs
# The "private key" is an ES256 key file (.p8) you create under Keys.
# APPLE_CLIENT_ID=com.example.app                # Services ID identifier
# APPLE_TEAM_ID=ABCDE12345
# APPLE_KEY_ID=ABCDE12345
# APPLE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
